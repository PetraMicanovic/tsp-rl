{
  "environment": {
    "grid_width": 100,
    "grid_height": 100,

    "start_position": [0, 0],
    "goal_position": [100, 100],

    "x_min": 10,
    "x_max": 90,
    "y_min": 10,
    "y_max": 90,

    "num_intermediate_points": [5, 10, 15, 20],

    "state_representation": "euclidean_distances",

    "action_space": {
      "type": "8-directional",
      "actions": {
        "UP": [0, 1],
        "DOWN": [0, -1],
        "LEFT": [-1, 0],
        "RIGHT": [1, 0],
        "UP_RIGHT": [1, 1],
        "UP_LEFT": [-1, 1],
        "DOWN_RIGHT": [1, -1],
        "DOWN_LEFT": [-1, -1]
      }
    },

    "random_seed": 42
  },

  "reward_function": {
    "cardinal_step_cost": -1.0, 
    "diagonal_step_cost": -1.414, 
    "goal_reward": 100.0,
    "out_of_bounds_penalty": -50.0
  },

  "training": {
    "episodes": 5000,
    "max_steps_per_episode": 500,

    "learning_rate": 0.1,
    "discount_factor": 0.99,

    "epsilon_start": 1.0,
    "epsilon_min": 0.05,
    "epsilon_decay": 0.995
  },

  "algorithms": {
    "sarsa": true,
    "q_learning": true,
    "double_q_learning": true,
    "n_step_sarsa": {
      "enabled": true,
      "n": 10
    }
  },

  "evaluation": {
    "save_results": true,
    "save_final_paths": true,
    "save_reward_curves": true,

    "plot_convergence": true,
    "compare_algorithms": true,

    "output_directory": "results"
  }
}
